{
  "schema_version": "1.0",
  "aragorn_version": "2.1.7",
  "enabled": true,
  "project": "serial-mcp-server",
  "preset": "standard",
  "base_branch": "main",
  "run_mode": "task",
  "phase_chain": [
    "init",
    "design",
    "dev",
    "testing",
    "checkpoint",
    "task-done"
  ],
  "mode": {
    "continue": false,
    "depth": "full"
  },
  "dev": {
    "engine": "teams",
    "mode": "auto",
    "worktree": true
  },
  "testing": {
    "bdd": true,
    "commands_are_authoritative": true,
    "engine": "auto",
    "per_task": "quick",
    "per_milestone": "full",
    "real_run": true,
    "tdd": false
  },
  "checkpoint": {
    "per_task": "codex",
    "per_milestone": "checkpoint-swarm",
    "write_history": true
  },
  "contract": {
    "require_task_spec": true,
    "granularity": "milestone",
    "boundary_mode": "warn_in_dev",
    "coverage_mode": "bound_only"
  },
  "qa": {
    "qaflow": true,
    "profile": "release",
    "real_verification": true,
    "require_gate_decision": true,
    "tdd": {
      "enforcement": "prompt"
    },
    "test_review": {
      "per_task": "skip",
      "per_milestone": "full"
    }
  },
  "verification": {
    "strictness": "follow",
    "engine": "auto",
    "checkpoint": "codex",
    "independent_required": true,
    "run_mode_override": "follow",
    "gates": {
      "init": "mechanical",
      "design": "independent",
      "dev": "independent",
      "testing": "independent",
      "checkpoint": "mechanical",
      "task-done": "mechanical"
    }
  },
  "auto_behavior": {
    "auto_problem_solve": true,
    "auto_problem_solve_max": 3,
    "continue_to_next_task": false,
    "continue_to_next_milestone": false,
    "stop_on_test_fail": true
  },
  "preferences": {
    "cli_first": true,
    "no_mocks": true,
    "docs_no_emoji": true
  },
  "teaching": {
    "map_mode": "on-demand",
    "level": "concise"
  }
}
